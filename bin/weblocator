#!/usr/bin/env ruby
# weblocator

# 20260304
# 0.1.0

# Changes:
# -/0: Use a heredoc template instead of the builder gem.
# 1. ~ Webloc#to_xml: Use heredoc.
# 2. public -> private Webloc#initialize

class Webloc
  def to_xml
    <<~XML
      <?xml version="1.0" encoding="UTF-8"?>
      <!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
      <plist version="1.0">
      <dict>
        <key>URL</key>
        <string>#{@url}</string>
      </dict>
      </plist>
    XML
  end

  private

  def initialize(url)
    @url = url
  end
end

def main
  puts Webloc.new(ARGV[0]).to_xml
end

main
