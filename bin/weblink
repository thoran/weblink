#!/usr/bin/env ruby
# weblink

# 20260304
# 0.5.0

# Changes since 0.4:
# -/0: Add --format switch to override platform default.
# 1. + require 'switches.rb'
# 2. + switches()
# 3. + supplied_format()
# 4. /native_extension/default_format/
# 5. + format()
# 6. ~ format_class(): Use format() instead of native_extension().

require 'rbconfig'
require 'switches.rb'

class DotDesktop
  def self.extension
    'desktop'
  end

  def generate
    <<~DESKTOP
      [Desktop Entry]
      Type=Link
      Name=#{@url}
      URL=#{@url}
      Icon=text-html
    DESKTOP
  end

  private

  def initialize(url)
    @url = url
  end
end

class DotUrl
  def self.extension
    'url'
  end

  def generate
    <<~INI
      [InternetShortcut]
      URL=#{@url}
      IconIndex=0
    INI
  end

  private

  def initialize(url)
    @url = url
  end
end

class DotWebloc
  def self.extension
    'webloc'
  end

  def generate
    <<~XML
      <?xml version="1.0" encoding="UTF-8"?>
      <!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
      <plist version="1.0">
      <dict>
        <key>URL</key>
        <string>#{@url}</string>
      </dict>
      </plist>
    XML
  end

  private

  def initialize(url)
    @url = url
  end
end

FORMAT_CLASSES = [DotDesktop, DotUrl, DotWebloc]

def switches
  @switches ||= (
    Switches.new do |s|
      s.set(:f, :format)
    end
  )
end

def url
  @url ||= (
    if ARGV[0]
      ARGV[0]
    elsif !$stdin.tty?
      $stdin.read.chomp
    end
  )
end

def supplied_format
  switches.format
end

def default_format
  case RbConfig::CONFIG['host_os']
  when /darwin/i; 'webloc'
  when /mswin|mingw|cygwin/i; 'url'
  when /linux|bsd/i; 'desktop'
  else; 'url'
  end
end

def format
  supplied_format || default_format
end

def format_class
  FORMAT_CLASSES.detect{|klass| klass.extension == format}
end

def main
  puts format_class.new(url).generate
end

main
