#!/usr/bin/env ruby
# weblink

# 20260422
# 0.10.0

# Description: A CLI program for generating and converting weblink or web shortcut files.

# Usage:
#   weblink <url>                             # generate, platform format, stdout
#   weblink <url> -f url                      # generate, explicit format, stdout
#   weblink <url> -o example.webloc           # generate, format from extension, file
#   weblink g <url>                           # generate, explicit sub-command
#   weblink example.webloc -f desktop         # convert, explicit format
#   weblink c example.webloc -f url           # convert, explicit sub-command
#   cat example.txt | weblink                 # generate from stdin which contains a URL, implicit sub-command
#   cat example.webloc | weblink              # convert from stdin, platform format
#   cat example.webloc | weblink -f url       # convert from stdin, explicit format
#   echo "https://example.com" | weblink      # generate from stdin, platform format, stdout
#   echo "https://example.com" | weblink g    # generate from stdin, explicit sub-command

require 'rbconfig'
require 'rexml/document'

module Thoran
  module Kernel
    module RequireGem

      def require_gem(load_string, gem_name: nil)
        require load_string
      rescue LoadError
        if gem_name
          system("gem install #{gem_name}")
        else
          system("gem install #{load_string}")
        end
        Gem.clear_paths
        require load_string
      end

    end
  end
end

Kernel.include(Thoran::Kernel::RequireGem)

require_gem 'switches.rb'

class DotDesktop
  def self.extension
    'desktop'
  end

  def self.load(path)
    parse(File.read(path))
  end

  def self.parse(content)
    content.each_line do |line|
      return WebLink.new($1) if line =~ /\AURL=(.+)/
    end
    nil
  end

  def generate
    <<~DESKTOP
      [Desktop Entry]
      Type=Link
      Name=#{@url}
      URL=#{@url}
      Icon=text-html
    DESKTOP
  end

  private

  def initialize(url)
    @url = url
  end
end

class DotUrl
  def self.extension
    'url'
  end

  def self.load(path)
    parse(File.read(path))
  end

  def self.parse(content)
    content.each_line do |line|
      return WebLink.new($1) if line =~ /\AURL=(.+)/
    end
    nil
  end

  def generate
    <<~INI
      [InternetShortcut]
      URL=#{@url}
      IconIndex=0
    INI
  end

  private

  def initialize(url)
    @url = url
  end
end

class DotWebloc
  def self.extension
    'webloc'
  end

  def self.load(path)
    parse(File.read(path))
  end

  def self.parse(content)
    doc = REXML::Document.new(content)
    found_key = false
    doc.elements.each('plist/dict/*') do |e|
      if found_key
        return WebLink.new(e.text)
      end
      found_key = true if e.name == 'key' && e.text == 'URL'
    end
    nil
  rescue REXML::ParseException
    nil
  end

  def generate
    <<~XML
      <?xml version="1.0" encoding="UTF-8"?>
      <!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
      <plist version="1.0">
      <dict>
        <key>URL</key>
        <string>#{@url}</string>
      </dict>
      </plist>
    XML
  end

  private

  def initialize(url)
    @url = url
  end
end

class WebLink
  FORMAT_CLASSES = [DotDesktop, DotUrl, DotWebloc]

  def self.load(path)
    file_ext = File.extname(path).delete_prefix('.')
    parse(File.read(path), format: file_ext)
  end

  def self.parse(content, format:)
    klass = FORMAT_CLASSES.detect{|format_klass| format_klass.extension == format}
    klass&.parse(content)
  end

  attr_accessor :url

  def to_desktop
    DotDesktop.new(@url)
  end

  def to_url
    DotUrl.new(@url)
  end

  def to_webloc
    DotWebloc.new(@url)
  end

  private

  def initialize(url)
    @url = url
  end
end

GENERATE_COMMAND_PATTERN = /^g(en(erate)?)?$/
CONVERT_COMMAND_PATTERN = /^c(onv(ert)?)?$/

def switches
  @switches ||= (
    Switches.new do |s|
      s.set(:f, :format)
      s.set(:o, :output)
    end
  )
end

def command_from_argv
  @command ||= (
    if command_present?
      ARGV[0]
    elsif ARGV[0] && File.exist?(ARGV[0])
      'convert'
    else
      'generate'
    end
  )
end

def weblink_from_stdin
  @weblink_from_stdin ||= (
    result = nil
    WebLink::FORMAT_CLASSES.each do |klass|
      result = klass.parse(stdin_content)
      break if result
    end
    result
  )
end

def command_from_stdin
  if command_present?
    ARGV[0]
  else
    weblink_from_stdin ? 'convert' : 'generate'
  end
end

def command
  @command ||= (
    if $stdin.tty?
      command_from_argv
    else
      command_from_stdin
    end
  )
end

def command_present?
  ARGV[0] && (
    ARGV[0].match?(GENERATE_COMMAND_PATTERN) ||
      ARGV[0].match?(CONVERT_COMMAND_PATTERN)
  )
end

def stdin_content
  @stdin_content ||= (
    $stdin.read.chomp unless $stdin.tty?
  )
end

def url_or_path
  @url_or_path ||= (
    if $stdin.tty?
      command_present? ? ARGV[1] : ARGV[0]
    else
      stdin_content
    end
  )
end

def output
  switches.output
end

def supplied_format
  switches.format
end

def format_from_output
  return unless output
  ext = File.extname(output).delete_prefix('.')
  ext unless ext.empty?
end

def default_format
  case RbConfig::CONFIG['host_os']
  when /darwin/i; 'webloc'
  when /mswin|mingw|cygwin/i; 'url'
  when /linux|bsd/i; 'desktop'
  else; 'url'
  end
end

def format
  supplied_format || format_from_output || default_format
end

def generate
  input = url_or_path
  if File.exist?(input)
    input = File.read(input)
  end
  web_link = WebLink.new(input).send("to_#{format}")
  if switches.output
    File.write(output, web_link.generate)
  else
    puts web_link.generate
  end
end

def convert
  if $stdin.tty?
    unless File.exist?(url_or_path)
      $stderr.puts "File not found: #{url_or_path}"
      exit 1
    end
    web_link = WebLink.load(url_or_path)
  else
    web_link = weblink_from_stdin
    unless web_link
      $stderr.puts "Could not parse input"
      exit 1
    end
  end
  dot_file = web_link.send("to_#{format}")
  if switches.output
    File.write(output, dot_file.generate)
  else
    puts dot_file.generate
  end
end

def main
  case command
  when GENERATE_COMMAND_PATTERN; generate
  when CONVERT_COMMAND_PATTERN; convert
  else; generate
  end
end

main if __FILE__ == $0
