#!/usr/bin/env ruby
# weblink

# 20260304
# 0.7.0

# Changes since 0.6:
# -/0: Optionally derive the format from the extension given by the output filename.
# 1. + format_from_output()
# 2. ~ format(): Use output format as second to the explicit format given with the --format switch.

require 'rbconfig'
require 'switches.rb'

class DotDesktop
  def self.extension
    'desktop'
  end

  def generate
    <<~DESKTOP
      [Desktop Entry]
      Type=Link
      Name=#{@url}
      URL=#{@url}
      Icon=text-html
    DESKTOP
  end

  private

  def initialize(url)
    @url = url
  end
end

class DotUrl
  def self.extension
    'url'
  end

  def generate
    <<~INI
      [InternetShortcut]
      URL=#{@url}
      IconIndex=0
    INI
  end

  private

  def initialize(url)
    @url = url
  end
end

class DotWebloc
  def self.extension
    'webloc'
  end

  def generate
    <<~XML
      <?xml version="1.0" encoding="UTF-8"?>
      <!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
      <plist version="1.0">
      <dict>
        <key>URL</key>
        <string>#{@url}</string>
      </dict>
      </plist>
    XML
  end

  private

  def initialize(url)
    @url = url
  end
end

FORMAT_CLASSES = [DotDesktop, DotUrl, DotWebloc]

def switches
  @switches ||= (
    Switches.new do |s|
      s.set(:f, :format)
      s.set(:o, :output)
    end
  )
end

def url
  @url ||= (
    if ARGV[0]
      ARGV[0]
    elsif !$stdin.tty?
      $stdin.read.chomp
    end
  )
end

def output
  switches.output
end

def supplied_format
  switches.format
end

def format_from_output
  return unless output
  ext = File.extname(output).delete_prefix('.')
  ext unless ext.empty?
end

def default_format
  case RbConfig::CONFIG['host_os']
  when /darwin/i; 'webloc'
  when /mswin|mingw|cygwin/i; 'url'
  when /linux|bsd/i; 'desktop'
  else; 'url'
  end
end

def format
  supplied_format || format_from_output || default_format
end

def format_class
  FORMAT_CLASSES.detect{|klass| klass.extension == format}
end

def main
  if switches.output
    File.write(output, format_class.new(url).generate)
  else
    puts format_class.new(url).generate
  end
end

main
